# Claims Approval System — environment configuration
# Copy this file to .env and fill in your values before running the app.
# .env is gitignored and must NEVER be committed to version control.
#
# Usage:
#   cp .env.example .env
#   then edit .env with your actual credentials

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=claims_db
DB_USER=claims_user
DB_PASS=change_me_to_a_strong_password

# ── Application ───────────────────────────────────────────────────────────────
# Set to "production" on live servers, "development" locally.
APP_ENV=development

# Full public URL of this installation (no trailing slash).
APP_URL=https://claims.rmu.edu.gh
